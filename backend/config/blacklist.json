[
  {
    "id": "fs-root-delete",
    "pattern": "\\brm\\s+-[A-Za-z]*[rf][A-Za-z]*\\s+/(\\s|$)",
    "flags": "i",
    "category": "filesystem-destruction",
    "riskLevel": "high",
    "description": "Recursively deleting the filesystem root is destructive."
  },
  {
    "id": "fs-home-delete",
    "pattern": "\\brm\\s+-[A-Za-z]*[rf][A-Za-z]*\\s+(~|/home)(/|\\s|$)",
    "flags": "i",
    "category": "filesystem-destruction",
    "riskLevel": "high",
    "description": "Bulk deletion of user home directories is destructive."
  },
  {
    "id": "fs-rm-wild-root",
    "pattern": "\\brm\\s+-[A-Za-z]*[rf][A-Za-z]*\\s+/\\*",
